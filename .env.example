# Use Ollama for chunking instead of OpenAI (set to "true" to use Ollama)
USE_OLLAMA=true

# OpenAI API Key (only needed if USE_OLLAMA=false)
OPENAI_API_KEY=your_openai_api_key_here

# Weaviate Configuration (local Docker)
WEAVIATE_URL=http://localhost:8080

# Ollama Configuration (local Docker)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Twitter/X API Credentials (get from developer.twitter.com)
TWITTER_API_KEY=your_api_key_here
TWITTER_API_SECRET=your_api_secret_here
TWITTER_ACCESS_TOKEN=your_access_token_here
TWITTER_ACCESS_TOKEN_SECRET=your_access_token_secret_here
